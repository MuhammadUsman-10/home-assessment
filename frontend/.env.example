# ── API URL (production: your Render backend URL ending in /api) ──
# Leave blank for local dev (Vite proxy handles it automatically)
VITE_API_URL=https://your-backend-name.onrender.com/api

# ── reCAPTCHA v2 Checkbox site key (from Google reCAPTCHA admin) ──
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key

# ── Google Maps (for store location picker) ──────────────────────
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key